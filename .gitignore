# C++ build artifacts (regenerated automatically, never need to be committed)
src/*.o
src/*.so
src/*.dll
src/*.a
*.dll

# Stan model executables — {instantiate} compiles these into the installed
# package's bin/stan/ directory, never into src/stan/ in the source tree, but
# ignore anything non-.stan here as a safety net for local ad hoc compiles.
src/stan/*
!src/stan/*.stan

# macOS files ----
.DS_Store

# History files ----
.Rhistory
.Rapp.history

# Session Data files ----
.RData
.Ruserdata

# RStudio files ----
*.Rproj
.Rproj.user/

# knitr cache
*_cache/
__packages/
/cache/
*knit.md
*utf8.md

# R Environment Variables ----
.Renviron

# User-specific files ----
README.html
.Rproj.user
.Rdata
.httr-oauth
.quarto
.pdf
/Meta/
/doc/
inst/doc
docs
inst/notebooks/bayesian_algorithm_output/
